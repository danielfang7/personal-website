---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title="Blog"
  description="Writing on engineering, design systems, startups, and building things on the internet."
>
  <div class="pt-32 section-padding">
    <div class="container-content max-w-3xl">
      <!-- Section header -->
      <div class="mb-16">
        <div class="flex items-center gap-3 mb-4">
          <span class="accent-line" aria-hidden="true" />
          <span class="text-sm font-medium tracking-widest text-accent uppercase">Writing</span>
        </div>
        <h1 class="font-display text-display-lg font-bold text-text-primary mb-4">
          Blog
        </h1>
        <p class="text-lg text-text-secondary leading-relaxed">
          Thoughts on engineering, design, and building products. Occasionally,
          something more personal.
        </p>
      </div>

      <!-- Post list -->
      {posts.length === 0 ? (
        <div class="rounded-2xl border border-border-subtle p-16 text-center">
          <p class="text-text-muted text-sm">Posts coming soon.</p>
        </div>
      ) : (
        <ul class="divide-y divide-border-subtle" role="list">
          {posts.map((post, i) => (
            <li class="blog-post-item anim-fade-up" style={`--delay: ${i * 60}ms`}>
              <a
                href={`/blog/${post.id.replace(/\.(md|mdx)$/, "")}`}
                class="group flex flex-col gap-2 py-8 hover:pl-2 transition-all duration-300 ease-out-expo"
              >
                <div class="flex items-center justify-between gap-6">
                  <h2 class="font-display font-semibold text-lg text-text-primary group-hover:text-accent transition-colors duration-200">
                    {post.data.title}
                  </h2>
                  <svg
                    class="shrink-0 text-text-muted opacity-0 group-hover:opacity-100 -translate-x-2 group-hover:translate-x-0 transition-all duration-300 ease-out-expo"
                    width="18"
                    height="18"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </div>
                <p class="text-sm text-text-secondary line-clamp-2">{post.data.excerpt}</p>
                <div class="flex items-center gap-4 mt-1">
                  <time class="text-xs text-text-muted" datetime={post.data.date.toISOString()}>
                    {formatDate(post.data.date)}
                  </time>
                  {post.data.readingTime && (
                    <span class="text-xs text-text-muted">{post.data.readingTime}</span>
                  )}
                  <ul class="flex items-center gap-2" role="list">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <li>
                        <span class="text-xs text-text-muted">{tag}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</BaseLayout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)"
  ).matches;

  if (!prefersReducedMotion) {
    gsap.utils.toArray<HTMLElement>(".blog-post-item").forEach((item, i) => {
      gsap.fromTo(
        item,
        { opacity: 0, x: -12 },
        {
          opacity: 1,
          x: 0,
          duration: 0.55,
          delay: i * 0.06,
          ease: "power3.out",
          scrollTrigger: {
            trigger: item,
            start: "top 90%",
            toggleActions: "play none none none",
          },
        }
      );
    });
  } else {
    document.querySelectorAll<HTMLElement>(".blog-post-item").forEach((el) => {
      el.style.opacity = "1";
    });
  }
</script>
