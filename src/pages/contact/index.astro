---
import BaseLayout from "@/layouts/BaseLayout.astro";

const socialLinks = [
  { label: "GitHub", href: "https://github.com/danielfang7", description: "See my open-source work" },
  { label: "LinkedIn", href: "https://linkedin.com/in/danielfang7", description: "Professional background" },
  { label: "X / Twitter", href: "https://twitter.com/danielfang7", description: "Thoughts in real time" },
];
---

<BaseLayout
  title="Contact"
  description="Get in touch with Daniel Fang — open to collaborations, conversations, and coffee chats."
>
  <div class="pt-32 section-padding">
    <div class="container-content max-w-2xl">
      <!-- Header -->
      <div class="mb-14">
        <div class="flex items-center gap-3 mb-4">
          <span class="accent-line" aria-hidden="true" />
          <span class="text-sm font-medium tracking-widest text-accent uppercase">Get in Touch</span>
        </div>
        <h1 class="font-display text-display-lg font-bold text-text-primary mb-4">
          Let's Talk
        </h1>
        <p class="text-lg text-text-secondary leading-relaxed">
          Whether you're working on something interesting, want to collaborate,
          or just want to say hello — my inbox is open.
        </p>
      </div>

      <!-- Email CTA -->
      <div class="p-8 rounded-2xl border border-border-subtle bg-bg-surface mb-10 group hover:border-border transition-colors duration-300">
        <p class="text-sm text-text-muted mb-2">Email</p>
        <a
          href="mailto:hello@danielfang.me"
          class="font-display font-semibold text-2xl text-text-primary hover:text-accent transition-colors duration-200 flex items-center gap-3 group"
        >
          hello@danielfang.me
          <svg
            class="text-text-muted group-hover:text-accent transition-all duration-300 group-hover:translate-x-1 group-hover:-translate-y-1"
            width="20"
            height="20"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>

      <!-- Social links -->
      <nav aria-label="Social media links">
        <p class="text-sm text-text-muted mb-5 uppercase tracking-widest font-medium">
          Find me on
        </p>
        <ul class="grid gap-3" role="list">
          {
            socialLinks.map(({ label, href, description }) => (
              <li>
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex items-center justify-between p-5 rounded-xl border border-border-subtle bg-bg-surface hover:border-border hover:-translate-y-0.5 transition-all duration-300 ease-out-expo"
                >
                  <div>
                    <span class="font-medium text-text-primary group-hover:text-accent transition-colors duration-200">
                      {label}
                    </span>
                    <p class="text-sm text-text-secondary mt-0.5">{description}</p>
                  </div>
                  <svg
                    class="text-text-muted opacity-0 group-hover:opacity-100 transition-all duration-300 -translate-x-2 group-hover:translate-x-0"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Location hint -->
      <p class="mt-12 text-sm text-text-muted text-center">
        Based in <span class="text-text-secondary">San Francisco, CA</span> · UTC−8
      </p>
    </div>
  </div>
</BaseLayout>
