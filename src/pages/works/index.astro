---
import BaseLayout from "@/layouts/BaseLayout.astro";
import WorksCarousel from "@/components/WorksCarousel.astro";
import { getCollection } from "astro:content";

const works = (await getCollection("works")).sort(
  (a, b) => a.data.order - b.data.order
);

function slug(id: string) {
  return id.replace(/\.(md|mdx)$/, "");
}
---

<BaseLayout
  title="Works"
  description="A collection of projects I've designed and built — exploring the intersection of craft, engineering, and product thinking."
>
  <!-- Carousel: the 3D scroll-linked showcase -->
  <WorksCarousel />

  <!-- Full project grid below the carousel -->
  <section class="section-padding border-t border-border-subtle" aria-label="All projects">
    <div class="container-content">
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-3">
          <span class="accent-line" aria-hidden="true" />
          <span class="text-sm font-medium tracking-widest text-accent uppercase">All Projects</span>
        </div>
        <h2 class="font-display text-display-md font-bold text-text-primary">
          Full Archive
        </h2>
      </div>

      <ul class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" role="list">
        {
          works.map((work, i) => (
            <li class="works-grid-card" style={`--delay: ${i * 60}ms`}>
              <a
                href={`/works/${slug(work.id)}`}
                class="group flex flex-col gap-4 p-5 rounded-2xl border border-border-subtle bg-bg-surface hover:border-border hover:-translate-y-1 transition-all duration-300 ease-out-expo"
              >
                <!-- Mini thumbnail / color swatch -->
                <div
                  class="h-1.5 w-10 rounded-full transition-all duration-300 group-hover:w-16"
                  style={`background: var(--color-accent);`}
                  aria-hidden="true"
                />

                <div class="flex items-start justify-between gap-3">
                  <h3 class="font-display font-semibold text-text-primary group-hover:text-accent transition-colors duration-200">
                    {work.data.title}
                  </h3>
                  <span class="text-xs text-text-muted mt-0.5 shrink-0">{work.data.year}</span>
                </div>

                <p class="text-sm text-text-secondary leading-relaxed line-clamp-2 -mt-2">
                  {work.data.description}
                </p>

                <div class="flex items-center justify-between gap-3 mt-auto">
                  <ul class="flex flex-wrap gap-1.5" role="list" aria-label="Tech stack">
                    {work.data.stack.slice(0, 3).map((tech) => (
                      <li>
                        <span class="text-[11px] px-2 py-0.5 rounded-full bg-bg-elevated text-text-muted border border-border-subtle">
                          {tech}
                        </span>
                      </li>
                    ))}
                  </ul>
                  <span class="text-xs text-text-muted shrink-0">{work.data.role}</span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    gsap.utils.toArray<HTMLElement>(".works-grid-card").forEach((card, i) => {
      gsap.fromTo(card,
        { opacity: 0, y: 28 },
        {
          opacity: 1, y: 0,
          duration: 0.55,
          delay: (i % 3) * 0.07,
          ease: "power3.out",
          scrollTrigger: {
            trigger: card,
            start: "top 88%",
            toggleActions: "play none none none",
          },
        }
      );
    });
  } else {
    document.querySelectorAll<HTMLElement>(".works-grid-card").forEach((el) => {
      el.style.opacity = "1";
    });
  }
</script>
