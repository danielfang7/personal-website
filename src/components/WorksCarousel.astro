---
import { getCollection } from "astro:content";

const works = (await getCollection("works")).sort(
  (a, b) => a.data.order - b.data.order
);

const gradients = [
  ["#6C63FF", "#A78BFA"],
  ["#06B6D4", "#3B82F6"],
  ["#10B981", "#06B6D4"],
  ["#F59E0B", "#EF4444"],
  ["#EC4899", "#8B5CF6"],
];

function slug(id: string) {
  return id.replace(/\.(md|mdx)$/, "");
}

const NAV_H = 80;
const META_HEIGHT = 88;
---

<section
  id="works-section"
  class="relative min-h-screen flex flex-col overflow-hidden"
  aria-label="Selected works"
>
  <!-- ── Section eyebrow ──────────────────────────────────────────────────── -->
  <div
    class="absolute left-0 right-0 z-30 pointer-events-none"
    style={`top: ${NAV_H + 20}px`}
    aria-hidden="true"
  >
    <div class="container-content flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="accent-line" />
        <span class="text-sm font-medium tracking-widest text-accent uppercase">
          Selected Works
        </span>
      </div>
      <a
        href="/works"
        class="pointer-events-auto text-sm text-text-secondary hover:text-text-primary transition-colors duration-200 flex items-center gap-2 group"
      >
        View all
        <svg
          class="-translate-x-1 group-hover:translate-x-0 transition-transform duration-200 ease-out-expo"
          width="15" height="15" viewBox="0 0 16 16" fill="none"
        >
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- ── Carousel region ──────────────────────────────────────────────────── -->
  <div
    id="carousel-pin"
    class="flex-1 flex flex-col items-center justify-center relative"
    style={`padding-top: ${NAV_H + 64}px; padding-bottom: 5rem;`}
    role="region"
    aria-roledescription="carousel"
    aria-label="Project carousel"
  >
    <!-- ── 3D stage ──────────────────────────────────────────────────────── -->
    <div
      id="carousel-stage"
      class="relative w-full overflow-visible"
      style="perspective: 680px; perspective-origin: 50% 50%;"
    >
      <!-- Side gradient masks -->
      <div
        class="pointer-events-none absolute inset-y-0 left-0 w-44 z-20"
        style="background: linear-gradient(to right, #0A0A0A 0%, transparent 100%);"
        aria-hidden="true"
      />
      <div
        class="pointer-events-none absolute inset-y-0 right-0 w-44 z-20"
        style="background: linear-gradient(to left, #0A0A0A 0%, transparent 100%);"
        aria-hidden="true"
      />

      <!-- Track -->
      <div
        id="carousel-track"
        class="flex items-center will-change-transform"
        style="gap: 2.5rem;"
      >
        {
          works.map((work, i) => {
            const [from, to] = gradients[i % gradients.length];
            return (
              <article
                class="carousel-card flex-shrink-0 will-change-transform"
                data-index={i}
                aria-label={work.data.title}
                aria-roledescription="slide"
                aria-setsize={works.length}
                aria-posinset={i + 1}
                tabindex="0"
              >
                <a
                  href={`/works/${slug(work.id)}`}
                  class="block focus-visible:outline-none group"
                  tabindex="-1"
                >
                  <div
                    class="relative overflow-hidden rounded-xl"
                    style="aspect-ratio: 16/10; box-shadow: 0 50px 120px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.06);"
                    transition:name={`project-visual-${slug(work.id)}`}
                  >
                    <div
                      class="absolute inset-0"
                      style={`background: linear-gradient(145deg, ${from}2a 0%, ${from}14 40%, ${to}1e 100%);`}
                      aria-hidden="true"
                    />
                    <div
                      class="absolute inset-0"
                      style="background-image: linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px); background-size: 40px 40px;"
                      aria-hidden="true"
                    />
                    <div
                      class="absolute inset-0 flex items-center justify-center"
                      aria-hidden="true"
                    >
                      <div
                        class="w-40 h-40 rounded-full blur-3xl opacity-50 transition-opacity duration-700 group-hover:opacity-80"
                        style={`background: ${from};`}
                      />
                    </div>
                    <div
                      class="absolute top-0 left-0 right-0 h-px"
                      style="background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.12) 50%, transparent 100%);"
                      aria-hidden="true"
                    />
                    <div
                      class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-300"
                      style="background: rgba(10,10,10,0.5); backdrop-filter: blur(4px);"
                      aria-hidden="true"
                    >
                      <span class="flex items-center gap-2 px-5 py-2.5 rounded-full bg-accent text-white text-sm font-semibold tracking-wide">
                        View Project
                        <svg width="13" height="13" viewBox="0 0 16 16" fill="none">
                          <path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    </div>
                  </div>
                </a>
              </article>
            );
          })
        }
      </div>

      <!-- ── Prev / Next arrows ────────────────────────────────────────────── -->
      <button
        id="carousel-prev"
        class="carousel-arrow absolute z-30 top-1/2 -translate-y-1/2"
        aria-label="Previous project"
        disabled
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button
        id="carousel-next"
        class="carousel-arrow absolute z-30 top-1/2 -translate-y-1/2"
        aria-label="Next project"
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

    <!-- ── Metadata — flows directly below the stage ─────────────────────── -->
    <div
      id="carousel-meta"
      class="relative z-30 mt-4 flex justify-center w-full"
      aria-live="polite"
      aria-atomic="true"
    >
      <div id="carousel-meta-inner" class="relative">
        {
          works.map((work, i) => (
            <div
              class="card-meta-panel absolute inset-x-0"
              data-index={i}
              aria-hidden={i !== 0 ? "true" : "false"}
              style={`opacity: ${i === 0 ? 1 : 0}; transform: translateY(${i === 0 ? 0 : 10}px);`}
            >
              <div class="flex items-baseline justify-between gap-4 mb-2">
                <a
                  href={`/works/${slug(work.id)}`}
                  class="font-display font-bold text-base md:text-lg text-text-primary hover:text-accent transition-colors duration-200 flex items-center gap-2 group"
                  tabindex="-1"
                >
                  {work.data.title}
                  <svg
                    class="text-text-muted group-hover:text-accent transition-all duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    width="13" height="13" viewBox="0 0 16 16" fill="none"
                  >
                    <path d="M4 12L12 4M12 4H6M12 4v6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </a>
                <span class="text-xs text-text-muted tabular-nums shrink-0">
                  {String(i + 1).padStart(2, "0")} / {String(works.length).padStart(2, "0")}
                </span>
              </div>
              <div class="flex items-center gap-5 pt-2 border-t border-border-subtle">
                <div>
                  <span class="text-[10px] tracking-widest text-text-muted uppercase block">Role</span>
                  <span class="text-sm text-text-secondary">{work.data.role}</span>
                </div>
                <div class="w-px h-6 bg-border-subtle" aria-hidden="true" />
                <div>
                  <span class="text-[10px] tracking-widest text-text-muted uppercase block">Year</span>
                  <span class="text-sm text-text-secondary">{work.data.year}</span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- ── Progress dots ────────────────────────────────────────────────────── -->
  <div
    id="carousel-dots"
    class="absolute bottom-8 left-0 right-0 flex items-center justify-center gap-2 z-30"
    role="tablist"
    aria-label="Carousel progress"
  >
    {
      works.map((work, i) => (
        <button
          class="carousel-dot h-1.5 rounded-full transition-colors"
          style="width: 6px; background: var(--color-border);"
          data-index={i}
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          aria-label={`Go to ${work.data.title}`}
          aria-controls="carousel-track"
        />
      ))
    }
  </div>
</section>

<style>
  .carousel-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(14, 14, 14, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--color-text-secondary);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    cursor: pointer;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      opacity 0.2s ease,
      transform 0.15s ease;
  }

  .carousel-arrow:hover:not(:disabled) {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
    transform: translateY(-50%) scale(1.08);
  }

  /* override the base top-1/2 -translate-y-1/2 when hovered */
  #carousel-stage .carousel-arrow {
    transform: translateY(-50%);
  }
  #carousel-stage .carousel-arrow:hover:not(:disabled) {
    transform: translateY(-50%) scale(1.08);
  }

  .carousel-arrow:disabled {
    opacity: 0.22;
    cursor: not-allowed;
  }

  .carousel-arrow:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }
</style>

<script>
  import { gsap } from "gsap";

  let carouselAbort: AbortController | null = null;

  function initCarousel() {
    if (carouselAbort) carouselAbort.abort();
    carouselAbort = new AbortController();

    const pin     = document.getElementById("carousel-pin");
    if (!pin) return;

    const stage     = document.getElementById("carousel-stage")!;
    const track     = document.getElementById("carousel-track")!;
    const metaInner = document.getElementById("carousel-meta-inner")!;
    const cards     = gsap.utils.toArray<HTMLElement>(".carousel-card");
    const dots      = gsap.utils.toArray<HTMLButtonElement>(".carousel-dot");
    const panels    = gsap.utils.toArray<HTMLElement>(".card-meta-panel");
    const prevBtn   = document.getElementById("carousel-prev") as HTMLButtonElement;
    const nextBtn   = document.getElementById("carousel-next") as HTMLButtonElement;
    const numCards  = cards.length;

    if (numCards === 0) return;

    const META_HEIGHT = 88;

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    // ── 3D constants ──────────────────────────────────────────────────────
    const ROT_MAX     = 42;
    const SCALE_MIN   = 0.72;
    const Z_MIN       = -130;
    const OPACITY_MIN = 0.28;
    const BLUR_MAX    = 3.5;

    // ── Responsive card width ─────────────────────────────────────────────
    function getCardWidth(): number {
      const vw = window.innerWidth;
      if (vw < 640)  return vw * 0.9;
      if (vw < 1024) return Math.min(vw * 0.62, 580);
      return Math.min(vw * 0.50, 700);
    }

    function getGap(): number {
      return window.innerWidth < 768 ? 20 : 40;
    }

    function getTrackBounds() {
      const w   = getCardWidth();
      const gap = getGap();
      const vw  = window.innerWidth;
      const startX = (vw - w) / 2;
      const endX   = startX - (numCards - 1) * (w + gap);
      return { startX, endX };
    }

    function updateLayout() {
      const w = getCardWidth();
      const h = w * (10 / 16); // 16:10 aspect ratio

      cards.forEach((c) => gsap.set(c, { width: w }));
      stage.style.height = `${h}px`;
      metaInner.style.width  = `${w}px`;
      metaInner.style.height = `${META_HEIGHT}px`;

      // Position arrows just outside the active card
      const arrowGap  = 16;
      const arrowSize = 44;
      prevBtn.style.left = `calc(50% - ${w / 2 + arrowGap + arrowSize}px)`;
      nextBtn.style.left = `calc(50% + ${w / 2 + arrowGap}px)`;
    }

    // ── Per-card 3D transforms ────────────────────────────────────────────
    function updateCards(progress: number) {
      const active = progress * (numCards - 1);
      cards.forEach((card, i) => {
        const dist = i - active;
        const absD = Math.abs(dist);
        const t    = Math.min(Math.pow(absD, 0.85), 1);

        gsap.set(card, {
          rotationY:      dist * ROT_MAX,
          scale:          1 - t * (1 - SCALE_MIN),
          z:              t * Z_MIN,
          opacity:        1 - t * (1 - OPACITY_MIN),
          filter:         `blur(${(t * BLUR_MAX).toFixed(1)}px)`,
          transformStyle: "preserve-3d",
          zIndex:         Math.round(20 - absD * 8),
        });
      });
    }

    // ── Metadata crossfade ────────────────────────────────────────────────
    let lastActivePanel = 0;

    function updateMeta(newIdx: number) {
      if (newIdx === lastActivePanel) return;

      const prev = lastActivePanel;
      lastActivePanel = newIdx;

      gsap.to(panels[prev], {
        opacity: 0, y: -8, duration: 0.3, ease: "power2.in",
        onComplete() { panels[prev].setAttribute("aria-hidden", "true"); },
      });
      gsap.fromTo(
        panels[newIdx],
        { opacity: 0, y: 10 },
        {
          opacity: 1, y: 0, duration: 0.4, ease: "power2.out",
          onStart() { panels[newIdx].setAttribute("aria-hidden", "false"); },
        }
      );
    }

    // ── Dot indicators ────────────────────────────────────────────────────
    function updateDots(idx: number) {
      dots.forEach((dot, i) => {
        dot.setAttribute("aria-selected", String(i === idx));
        gsap.to(dot, {
          width:      i === idx ? 22 : 6,
          background: i === idx ? "var(--color-accent)" : "var(--color-border)",
          duration:   0.35,
          ease:       "power2.out",
        });
      });
    }

    // ── Arrow enabled state ───────────────────────────────────────────────
    function updateArrows(idx: number) {
      prevBtn.disabled = idx === 0;
      nextBtn.disabled = idx === numCards - 1;
    }

    // ── Navigate to card by index ─────────────────────────────────────────
    let currentIndex = 0;
    let isAnimating  = false;

    function goToCard(idx: number) {
      const newIdx = gsap.utils.clamp(0, numCards - 1, idx);
      if (newIdx === currentIndex || isAnimating) return;

      isAnimating = true;
      currentIndex = newIdx;

      updateMeta(newIdx);
      updateDots(newIdx);
      updateArrows(newIdx);

      const p = numCards > 1 ? newIdx / (numCards - 1) : 0;
      const { startX, endX } = getTrackBounds();
      const targetX = gsap.utils.interpolate(startX, endX, p);

      gsap.to(track, {
        x: targetX,
        duration: 0.65,
        ease: "power2.inOut",
        onUpdate() {
          const curX = gsap.getProperty(track, "x") as number;
          const { startX: sx, endX: ex } = getTrackBounds();
          const curP = ex !== sx ? (curX - sx) / (ex - sx) : 0;
          updateCards(curP);
        },
        onComplete() {
          updateCards(p);
          isAnimating = false;
        },
      });
    }

    // ─────────────────────────────────────────────────────────────────────
    // REDUCED MOTION: static grid, no 3D
    // ─────────────────────────────────────────────────────────────────────
    if (prefersReducedMotion) {
      gsap.set(stage, { perspective: "none" });
      gsap.set(track, {
        display: "grid",
        gridTemplateColumns: "repeat(auto-fill, minmax(min(100%, 340px), 1fr))",
        gap: "1.5rem",
        padding: "1.5rem",
      });
      cards.forEach((c) => gsap.set(c, { width: "100%", opacity: 1 }));
      document.getElementById("carousel-meta")!.style.display = "none";
      prevBtn.style.display = "none";
      nextBtn.style.display = "none";
      updateDots(0);
    } else {
      // ─────────────────────────────────────────────────────────────────
      // FULL CAROUSEL
      // ─────────────────────────────────────────────────────────────────

      updateLayout();
      const { startX } = getTrackBounds();
      gsap.set(track, { x: startX });
      updateCards(0);
      updateDots(0);
      updateArrows(0);

      // Button clicks
      prevBtn.addEventListener("click", () => goToCard(currentIndex - 1), { signal: carouselAbort!.signal });
      nextBtn.addEventListener("click", () => goToCard(currentIndex + 1), { signal: carouselAbort!.signal });

      // Dot clicks
      dots.forEach((dot, i) =>
        dot.addEventListener("click", () => goToCard(i), { signal: carouselAbort!.signal })
      );

      // Card focus
      cards.forEach((card, i) =>
        card.addEventListener("focus", () => goToCard(i), { capture: true, signal: carouselAbort!.signal })
      );

      // Keyboard navigation
      pin.addEventListener("keydown", (e: KeyboardEvent) => {
        if (e.key === "ArrowRight" || e.key === "ArrowDown") {
          e.preventDefault(); goToCard(currentIndex + 1);
        } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
          e.preventDefault(); goToCard(currentIndex - 1);
        }
      }, { signal: carouselAbort!.signal });

      // Resize handler
      let resizeTm: ReturnType<typeof setTimeout>;
      window.addEventListener("resize", () => {
        clearTimeout(resizeTm);
        resizeTm = setTimeout(() => {
          updateLayout();
          const p = numCards > 1 ? currentIndex / (numCards - 1) : 0;
          const { startX: sx, endX: ex } = getTrackBounds();
          gsap.set(track, { x: gsap.utils.interpolate(sx, ex, p) });
          updateCards(p);
        }, 150);
      }, { signal: carouselAbort!.signal });
    }
  }

  let _carouselFired = false;
  document.addEventListener("astro:page-load", () => {
    _carouselFired = true;
    initCarousel();
  });
  requestAnimationFrame(() => {
    if (!_carouselFired) initCarousel();
  });
</script>
